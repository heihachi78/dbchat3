      <data key="d0">Large Data Loads</data>
      <data key="d1">event</data>
      <data key="d2">Large Data Loads are bulk data insertion or update operations that can impact index performance and may require index maintenance such as rebuilds.</data>
      <data key="d3">chunk-a41048dcaa5356d2ec9a434224117f92</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988676</data>
