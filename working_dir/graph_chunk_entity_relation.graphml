    <node id="City">
      <data key="d0">City</data>
      <data key="d1">geo</data>
      <data key="d2">City refers to the urban area where a company location (office, warehouse, or production site) is situated, as stored in the CITY column of the LOCATIONS table.</data>
      <data key="d3">chunk-0d57c05e29cac79ec75bdc43f56c5d29</data>
