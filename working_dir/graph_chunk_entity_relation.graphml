    <node id="HR.LOCATIONS Table">
      <data key="d0">HR.LOCATIONS Table</data>
      <data key="d1">category</data>
      <data key="d2">The HR.LOCATIONS table is a foundational database object within the HR schema that stores detailed address and geographic information for company locations including offices, warehouses, and production sites. It enforces data integrity through primary and foreign key constraints and integrates with the COUNTRIES table for comprehensive location data.</data>
      <data key="d3">chunk-f863663ead003b009e2b4af32de47158</data>
      <data key="d4">unknown_source</data>
