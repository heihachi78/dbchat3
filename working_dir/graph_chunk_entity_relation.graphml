      <data key="d0">Department-level Access Controls</data>
      <data key="d1">category</data>
      <data key="d2">Department-level access controls are security mechanisms that restrict or allow access to employee data based on department, supported by queries using the EMP_DEPARTMENT_IX index.</data>
      <data key="d3">chunk-a01dcf1c9756eb26a45470d65ee6f338</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988669</data>
