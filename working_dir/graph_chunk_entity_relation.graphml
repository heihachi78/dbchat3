    <node id="LOC_STATE_PROVINCE_IX">
      <data key="d0">LOC_STATE_PROVINCE_IX</data>
      <data key="d1">category</data>
      <data key="d2">LOC_STATE_PROVINCE_IX is a non-unique B-tree index on the STATE_PROVINCE column of the hr.LOCATIONS table, designed to improve query performance for filtering or sorting by state or province in geographic or regional data contexts.</data>
      <data key="d3">chunk-38310d95744bbc5c98b7150c7d4a14b6</data>
      <data key="d4">unknown_source</data>
