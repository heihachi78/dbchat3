      <data key="d0">department-based queries and operations</data>
      <data key="d1">category</data>
      <data key="d2">Department-based queries and operations refer to database activities that filter, group, or process employee data according to department assignments, benefiting from the EMP_DEPARTMENT_IX index.</data>
      <data key="d3">chunk-a41048dcaa5356d2ec9a434224117f92</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988676</data>
