    </node>
    <node id="Check Constraint: END_DATE &gt; START_DATE">
      <data key="d0">Check Constraint: END_DATE &gt; START_DATE</data>
      <data key="d1">category</data>
      <data key="d2">A validation rule in HR.JOB_HISTORY that enforces the chronological order of job assignments by ensuring END_DATE is later than START_DATE.</data>
      <data key="d3">chunk-6c187f531b2027607e34d96862df8d99</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1753912873</data>
    </node>
    <node id="Primary Key (EMPLOYEE_ID, START_DATE)">
      <data key="d0">Primary Key (EMPLOYEE_ID, START_DATE)</data>
      <data key="d1">category</data>
      <data key="d2">A composite primary key in HR.JOB_HISTORY that uniquely identifies each job history record by employee and start date, supporting historical versioning.</data>
      <data key="d3">chunk-6c187f531b2027607e34d96862df8d99</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1753912875</data>
