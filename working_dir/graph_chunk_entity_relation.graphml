    <node id="Special Features">
      <data key="d0">Special Features</data>
      <data key="d1">category</data>
      <data key="d2">Special features include the use of fixed-length CHAR data type for COUNTRY_ID to optimize storage and indexing for country codes.&lt;SEP&gt;Special features of HR.JOB_HISTORY include enforced date interval constraints to prevent overlapping job periods and composite primary key support for historical versioning.</data>
      <data key="d3">chunk-f863663ead003b009e2b4af32de47158&lt;SEP&gt;chunk-6c187f531b2027607e34d96862df8d99</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1753912877</data>
