    <node id="Maintenance">
      <data key="d0">Maintenance</data>
      <data key="d1">category</data>
      <data key="d2">Maintenance activities for HR.JOB_HISTORY include regular integrity checks for foreign key consistency and archival strategies for large historical data sets.&lt;SEP&gt;Maintenance involves regular integrity checks to ensure foreign key consistency and index maintenance on primary keys for performance.</data>
      <data key="d3">chunk-f863663ead003b009e2b4af32de47158&lt;SEP&gt;chunk-6c187f531b2027607e34d96862df8d99</data>
