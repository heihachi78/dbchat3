    <node id="Business Entities">
      <data key="d0">Business Entities</data>
      <data key="d1">category</data>
      <data key="d2">Business Entities refer to offices, warehouses, stores, and other organizational units whose geographic data is stored in the LOCATIONS table.</data>
      <data key="d3">chunk-38310d95744bbc5c98b7150c7d4a14b6</data>
