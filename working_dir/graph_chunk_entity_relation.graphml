      <data key="d0">Analytics and Dashboards</data>
      <data key="d1">category</data>
      <data key="d2">Analytics and dashboards are business intelligence tools that aggregate and visualize employee data by department, relying on the EMP_DEPARTMENT_IX index for efficient data access.</data>
      <data key="d3">chunk-a01dcf1c9756eb26a45470d65ee6f338</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988669</data>
    </node>
    <node id="Joins Between EMPLOYEES and DEPARTMENTS">
      <data key="d0">Joins Between EMPLOYEES and DEPARTMENTS</data>
      <data key="d1">category</data>
      <data key="d2">Joins between EMPLOYEES and DEPARTMENTS are database operations that combine employee and department data, typically using the DEPARTMENT_ID column and accelerated by the EMP_DEPARTMENT_IX index.</data>
      <data key="d3">chunk-a01dcf1c9756eb26a45470d65ee6f338</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988669</data>
    </node>
