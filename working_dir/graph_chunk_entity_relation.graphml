    <node id="Hr.Regions">
      <data key="d0">Hr.Regions</data>
      <data key="d1">organization</data>
      <data key="d2">The hr.REGIONS table is a core reference entity within the HR schema that defines geographic regions. It stores unique numeric identifiers and optional region names, serving as a foundational element for geographic classification in HR-related business processes such as reporting, payroll, compliance, and resource allocation.</data>
      <data key="d3">chunk-f36c7f7c4e6a172a92fe1ea27e35db14</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1753912756</data>
