    <node id="Organizational chart generation">
      <data key="d0">Organizational chart generation</data>
      <data key="d1">category</data>
      <data key="d2">Organizational chart generation is a business process that creates visual representations of the structure of an organization, often grouping employees by job role or function.</data>
