    <node id="COUNTR_REG_FK">
      <data key="d0">COUNTR_REG_FK</data>
      <data key="d1">category</data>
      <data key="d2">COUNTR_REG_FK is the foreign key constraint on the REGION_ID column in the HR.COUNTRIES table, enforcing referential integrity by requiring REGION_ID values to exist in the HR.REGIONS table.</data>
