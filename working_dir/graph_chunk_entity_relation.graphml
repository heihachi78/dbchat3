    <node id="B-tree Indexing">
      <data key="d0">B-tree Indexing</data>
      <data key="d1">category</data>
      <data key="d2">B-tree indexing is a standard database indexing method used to organize and access data efficiently. It is the structure used by EMP_JOB_IX.</data>
