    <node id="Compression">
      <data key="d0">Compression</data>
      <data key="d1">category</data>
      <data key="d2">A data storage technique that is disabled in the B-tree index to avoid CPU overhead during index creation.&lt;SEP&gt;Compression is a database feature that reduces storage size of data or indexes, which can impact performance and complexity.</data>
      <data key="d3">chunk-799db255698d9ddf0d4c7649135906d0&lt;SEP&gt;chunk-7f3a649840d8c0d19c4f0b28731832a5</data>
