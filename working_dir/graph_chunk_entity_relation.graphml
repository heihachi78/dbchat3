    <node id="Queries, Views, Procedures">
      <data key="d0">Queries, Views, Procedures</data>
      <data key="d1">category</data>
      <data key="d2">Queries, Views, and Procedures are database objects that utilize the HR.JHIST_EMPLOYEE_IX index to filter or join on EMPLOYEE_ID, benefiting from improved performance.&lt;SEP&gt;Queries, views, and procedures are database objects that depend on the LOC_CITY_IX index to improve performance when filtering or sorting by the CITY column.</data>
      <data key="d3">chunk-711d8bcdc23c815a60cb46edd6c7c69e&lt;SEP&gt;chunk-b70313252212b24335f3373f61fa80d1</data>
      <data key="d4">unknown_source</data>
