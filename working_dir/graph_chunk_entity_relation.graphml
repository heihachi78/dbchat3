    <node id="Regional Analysis">
      <data key="d0">Regional Analysis</data>
      <data key="d1">category</data>
      <data key="d2">Regional Analysis involves examining data segmented by state or province, supported by efficient queries enabled by the LOC_STATE_PROVINCE_IX index.</data>
      <data key="d3">chunk-38310d95744bbc5c98b7150c7d4a14b6</data>
      <data key="d4">unknown_source</data>
