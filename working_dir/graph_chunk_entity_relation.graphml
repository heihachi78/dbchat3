      <data key="d1">category</data>
      <data key="d2">These are database operations and business reports that filter or join employee data based on department, benefiting from the EMP_DEPARTMENT_IX index.</data>
      <data key="d3">chunk-a01dcf1c9756eb26a45470d65ee6f338</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988669</data>
    </node>
    <node id="Application Logic or Stored Procedures">
      <data key="d0">Application Logic or Stored Procedures</data>
      <data key="d1">category</data>
      <data key="d2">Application logic or stored procedures are automated routines or code that access employees by department, often using the EMP_DEPARTMENT_IX index for efficiency.</data>
      <data key="d3">chunk-a01dcf1c9756eb26a45470d65ee6f338</data>
      <data key="d4">hr.emp_department_ix.md</data>
      <data key="d5">1753988669</data>
    </node>
    <node id="Bulk Data Loads or Rebuilds">
      <data key="d0">Bulk Data Loads or Rebuilds</data>
      <data key="d1">event</data>
      <data key="d2">Bulk data loads or rebuilds are database maintenance events where large volumes of data are inserted or indexes are rebuilt, often using NOLOGGING to improve performance.</data>
